# ============================================================
# Copia este archivo como variables.env y completa los valores
# NUNCA subas variables.env al repositorio
# ============================================================

# --- Variables de Base de Datos ---
POSTGRES_USER=tu_usuario_db
POSTGRES_PASSWORD=tu_password_db
POSTGRES_DB=fatima_db

# --- Variables de Directus (Backend y CMS) ---
# Genera valores únicos en: https://www.uuidgenerator.net/
KEY=REEMPLAZA-CON-UUID-UNICO
SECRET=REEMPLAZA-CON-UUID-UNICO

# Credenciales del administrador de Directus (Fátima)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=tu_password_segura

# Conexión entre Directus y la Base de datos PostgreSQL
DB_CLIENT=pg
DB_HOST=db
DB_PORT=5432
DB_DATABASE=fatima_db
DB_USER=tu_usuario_db
DB_PASSWORD=tu_password_db

# URL pública de Directus
PUBLIC_URL=http://localhost:8055

# CORS — agrega los dominios que necesiten acceso
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
CORS_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_CREDENTIALS=true
